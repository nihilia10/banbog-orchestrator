{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 180 }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ]
}
